rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // HELPER FUNCTIONS
    // =========================

    // User is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Path to current user doc
    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    // User document exists
    function userExists() {
      return isAuthenticated() && exists(userDocPath());
    }

    // Current user data
    function currentUser() {
      return get(userDocPath()).data;
    }

    // User is active
    function isActive() {
      return userExists() && currentUser().status == 'active';
    }

    // Has specific role
    function hasRole(role) {
      return userExists() && currentUser().role == role;
    }

    function isSuperEditor() {
      return hasRole('super_editor');
    }

    function isEditor() {
      return hasRole('editor');
    }

    function isViewer() {
      return hasRole('viewer');
    }

    // Can edit events (editor + super editor)
    function canEdit() {
      return (isEditor() || isSuperEditor()) && isActive();
    }

    // Can use calendar at all (viewer/editor/super_editor) and active
    function canUseCalendar() {
      return isActive() && currentUser().role != 'pending';
    }

    // Editor/Super Editor can manage artists if artistIds intersect managedArtistIds
    function canManageArtists(artistIds) {
      return isActive() && (
        currentUser().role == 'super_editor' ||
        (
          currentUser().role == 'editor' &&
          (artistIds is list) &&
          (currentUser().managedArtistIds is list) &&
          artistIds.hasAny(currentUser().managedArtistIds)
        )
      );
    }

    // Check if user can view a specific event
    // - super_editor: all events
    // - editor: events with artistIds ∩ managedArtistIds ≠ ∅
    // - viewer: events that contain viewer's artistId
    function canViewEvent(eventData) {
      return isActive() && (
        currentUser().role == 'super_editor' ||
        (
          currentUser().role == 'editor' &&
          (eventData.artistIds is list) &&
          (currentUser().managedArtistIds is list) &&
          eventData.artistIds.hasAny(currentUser().managedArtistIds)
        ) ||
        (
          currentUser().role == 'viewer' &&
          ('artistId' in currentUser()) &&
          (eventData.artistIds is list) &&
          eventData.artistIds.hasAny([currentUser().artistId])
        )
      );
    }

    // =========================
    // USERS
    // =========================

    match /users/{userId} {

      // Current user reads own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;

      // Super Editor can read all users
      allow read: if isSuperEditor();

      // First-time creation: pending user
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.role == 'pending'
        && request.resource.data.status == 'active'
        && (
          !('managedArtistIds' in request.resource.data) ||
          request.resource.data.managedArtistIds.size() == 0
        );

      // Super Editor can update users (approve, set role, artistId, managedArtistIds)
      allow update: if isSuperEditor();

      // User can update own fcmToken + updatedAt only
      allow update: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['fcmToken', 'updatedAt']);

      // Never allow delete from client
      allow delete: if false;
    }

    // =========================
    // ARTISTS
    // =========================

    match /artists/{artistId} {
      // Any authenticated user can read artists (including pending)
      // This allows the app to load data while waiting for approval
      allow read: if isAuthenticated();

      // Only Super Editor can manage artists
      allow create, update, delete: if isSuperEditor() && isActive();
    }

    // =========================
    // EVENTS
    // =========================

    match /events/{eventId} {

      // Read single document: check if user can view this specific event
      allow get: if userExists() && canViewEvent(resource.data);
      
      // List/Query events: trust the client-side query filtering
      // We can't check arrayContainsAny in rules, so we allow queries
      // and rely on the client app to filter correctly
      allow list: if isActive() && currentUser().role != 'pending';

      // Super Editor full write access
      allow create, update, delete: if isSuperEditor() && isActive();

      // Editor can create events only for artists they manage
      allow create: if isEditor()
        && isActive()
        && canManageArtists(request.resource.data.artistIds);

      // Editor can update events only if old & new artistIds are in their managedArtistIds
      allow update: if isEditor()
        && isActive()
        && canManageArtists(resource.data.artistIds)
        && canManageArtists(request.resource.data.artistIds);

      // Editor can delete events they manage
      allow delete: if isEditor()
        && isActive()
        && canManageArtists(resource.data.artistIds);
    }

    // =========================
    // EVENT TYPES
    // =========================

    match /event_types/{typeId} {
      // Any authenticated user can read event types
      allow read: if isAuthenticated();
      allow create, update, delete: if isSuperEditor() && isActive();
    }

    // =========================
    // REMINDERS
    // =========================

    match /reminders/{reminderId} {
      // Read reminders if user can view linked event (simplified: must be able to use calendar)
      allow read: if canUseCalendar();

      // Only editors & super editors can manage reminders
      allow create, update, delete: if canEdit();
    }

    // =========================
    // NOTIFICATIONS
    // =========================

    match /notifications/{notificationId} {
      // User can read their own notifications
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      // User can update own notification (mark as read only)
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['isRead']);

      // User can delete their own notifications
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      // Super Editor or system (Cloud Functions) can create notifications
      allow create: if isSuperEditor()
        || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
    }

    // =========================
    // NOTIFICATION JOBS
    // =========================

    match /notification_jobs/{jobId} {
      // User can read own jobs
      allow read: if isAuthenticated()
        && resource.data.recipientUserId == request.auth.uid;

      // Client cannot write; only Cloud Functions
      allow write: if false;
    }

    // =========================
    // DEFAULT DENY
    // =========================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}